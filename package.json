{
  "name": "opencode-forge",
  "version": "0.4.17",
  "type": "module",
  "oc-plugin": [
    "server",
    "tui"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist",
    "forge-config.jsonc",
    "scripts",
    "README.md",
    "src/command/template",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chriswritescode-dev/opencode-forge.git"
  },
  "author": "Chris Scott",
  "description": "OpenCode Forge - autonomous dev loops, plan storage, and sandboxing for OpenCode",
  "image": "https://raw.githubusercontent.com/chriswritescode-dev/opencode-forge/main/opengraph-image.png",
  "keywords": [
    "opencode",
    "iterative-loops",
    "ai-agent",
    "plugin",
    "forge"
  ],
  "license": "MIT",
  "homepage": "https://github.com/chriswritescode-dev/opencode-forge",
  "dependencies": {
    "@opencode-ai/plugin": "1.15.5",
    "@opencode-ai/sdk": "1.15.5",
    "jsonc-parser": "^3.3.1",
    "web-tree-sitter": "0.25.10"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.1.105",
    "@opentui/solid": ">=0.1.105"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@esbuild/linux-arm64": "^0.21.5",
    "@eslint/js": "^10.0.1",
    "@opentui/core": "0.1.105",
    "@opentui/solid": "0.1.105",
    "@rollup/rollup-linux-arm64-gnu": "^4.60.3",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "better-sqlite3": "^12.9.0",
    "bun-types": "latest",
    "eslint": "^10.2.0",
    "eslint-plugin-solid": "^0.14.5",
    "solid-js": "^1.9.12",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dashboard": "bun scripts/dashboard.ts",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:bun": "bun test --max-concurrency=1",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc",
    "docs": "pnpm docs:api"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}

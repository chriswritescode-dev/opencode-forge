{
  "name": "opencode-forge",
  "version": "0.3.0",
  "type": "module",
  "oc-plugin": [
    "server",
    "tui"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist",
    "forge-config.jsonc",
    "scripts",
    "README.md",
    "src/command/template"
  ],
  "bin": {
    "oc-forge": "./dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chriswritescode-dev/opencode-forge.git"
  },
  "author": "Chris Scott",
  "description": "OpenCode Forge - autonomous dev loops, plan storage, and sandboxing for OpenCode",
  "image": "https://raw.githubusercontent.com/chriswritescode-dev/opencode-forge/main/opengraph-image.png",
  "keywords": [
    "opencode",
    "iterative-loops",
    "ai-agent",
    "plugin",
    "forge"
  ],
  "license": "MIT",
  "homepage": "https://github.com/chriswritescode-dev/opencode-forge",
  "dependencies": {
    "@ast-grep/lang-bash": "^0.0.8",
    "@ast-grep/lang-c": "^0.0.6",
    "@ast-grep/lang-cpp": "^0.0.6",
    "@ast-grep/lang-csharp": "^0.0.6",
    "@ast-grep/lang-css": "^0.0.7",
    "@ast-grep/lang-dart": "^0.0.7",
    "@ast-grep/lang-elixir": "^0.0.7",
    "@ast-grep/lang-go": "^0.0.6",
    "@ast-grep/lang-html": "^0.0.7",
    "@ast-grep/lang-java": "^0.0.7",
    "@ast-grep/lang-javascript": "^0.0.7",
    "@ast-grep/lang-json": "^0.0.7",
    "@ast-grep/lang-kotlin": "^0.0.7",
    "@ast-grep/lang-php": "^0.0.7",
    "@ast-grep/lang-python": "^0.0.6",
    "@ast-grep/lang-ruby": "^0.0.7",
    "@ast-grep/lang-rust": "^0.0.7",
    "@ast-grep/lang-scala": "^0.0.7",
    "@ast-grep/lang-swift": "^0.0.8",
    "@ast-grep/lang-toml": "^0.0.9",
    "@ast-grep/lang-tsx": "^0.0.7",
    "@ast-grep/lang-typescript": "^0.0.7",
    "@ast-grep/lang-yaml": "^0.0.6",
    "@ast-grep/napi": "^0.42.1",
    "@opencode-ai/plugin": "^1.14.30",
    "@opencode-ai/sdk": "^1.14.30"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.1.105",
    "@opentui/solid": ">=0.1.105"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opentui/core": "0.1.105",
    "@opentui/solid": "0.1.105",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "bun-types": "latest",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.8.1",
    "solid-js": "^1.9.12",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build",
    "test": "bun test --max-concurrency=1",
    "typecheck": "tsc --noEmit",
    "cli": "bun src/cli/index.ts",
    "docs:api": "typedoc",
    "docs": "pnpm docs:api"
  }
}
